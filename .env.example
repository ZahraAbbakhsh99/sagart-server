# ENVIRONMENT SELECTOR
# --------------------------------
# development | production
NODE_ENV=development


# APPLICATION
PORT=3000

# POSTGRESQL DATABASE
DATABASE_URL=postgresql://username:password@localhost:5433/sagart_db

# JWT AUTHENTICATION
JWT_SECRET=super_secret_key_here
JWT_EXPIRES_IN=7d

# ZARINPAL PAYMENT
ZARINPAL_MERCHANT_ID=merchant_id
ZARINPAL_CALLBACK_URL=http://localhost:3000/payments/verify